# Copy to .env and fill values as needed.
# Do not commit .env

# App
APP_ENV=development
APP_URL=http://localhost:3000

# Analytics (optional)
ANALYTICS_PROVIDER=
ANALYTICS_WRITE_KEY=

# Error monitoring (optional)
SENTRY_DSN=

# Database (Postgres)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
# Required for: prisma migrate / prisma studio / runtime DB access
DATABASE_URL=postgresql://postgres:password@localhost:5432/job_hunt_tracker?schema=public
