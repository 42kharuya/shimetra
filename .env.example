# Copy to .env and fill values as needed.
# Do not commit .env

# App
APP_ENV=development
APP_URL=http://localhost:3000

# Analytics (optional)
ANALYTICS_PROVIDER=
ANALYTICS_WRITE_KEY=

# Error monitoring (optional)
SENTRY_DSN=

# Database (Postgres)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
# Required for: prisma migrate / prisma studio / runtime DB access
DATABASE_URL=postgresql://postgres:password@localhost:5432/job_hunt_tracker?schema=public

# Email
# EMAIL_PROVIDER: "console"（ローカル開発・stdout出力）/ "resend"（本番）
EMAIL_PROVIDER=console
# Resend API キー（EMAIL_PROVIDER=resend のときのみ必須）
# https://resend.com/api-keys
RESEND_API_KEY=
# 送信元アドレス（Resendで認証済みドメイン、例: noreply@yourdomain.com）
EMAIL_FROM=

# Auth（マジックリンク認証）
# openssl rand -base64 32 で生成してください
AUTH_SECRET=
# マジックリンクの有効期限（分）. デフォルト: 30
MAGIC_LINK_EXPIRY_MINUTES=30

# Stripe（課金）
# https://dashboard.stripe.com/apikeys
# テスト用: sk_test_xxxxx / 本番: sk_live_xxxxx
STRIPE_SECRET_KEY=
# Pro プランの Price ID（Stripe ダッシュボードで作成）
# 月額 980円 の recurring price を作成し、その ID を設定する
# 例: price_xxxxx
STRIPE_PRICE_ID=
# Stripe Webhook 署名シークレット
# ローカル: stripe listen --forward-to localhost:3000/api/stripe/webhook で取得した whsec_xxx
# 本番: Stripe Dashboard > Developers > Webhooks > エンドポイント詳細 > Signing secret
STRIPE_WEBHOOK_SECRET=
